# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini AI (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Notion (optional — for real Notion pages in entity Integrations tab)
# Create at https://www.notion.so/my-integrations, then share each page with the integration
NOTION_API_KEY=your-notion-integration-secret

# Required for creating entity pages (API/script). Default parent under which entity pages are created.
# Create a page in Notion, open it, copy its ID from the URL: notion.so/.../<PAGE_ID>
NOTION_PARENT_PAGE_ID=your-parent-page-id

# Optional: different Notion parent per jurisdiction (country_code → page ID). Fallback: NOTION_PARENT_PAGE_ID. Use 13 only: JP, DE, FR, SG, NL, SE, GB, AE, IN, KR, BR, CA, AU.
# NOTION_PARENT_PAGE_IDS_BY_JURISDICTION={"JP":"...","DE":"...","FR":"...","SG":"...","NL":"...","SE":"...","GB":"...","AE":"...","IN":"...","KR":"...","BR":"...","CA":"...","AU":"..."}

# Google Drive (optional — for real Drive files in entity Integrations tab)
# Service account JSON as a single line (minify) or escaped; folder must be shared with the service account email
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Optional: single default Drive folder for all entities without metadata.drive_folder_id. Share with service account. No DRIVE_FOLDER_IDS_BY_JURISDICTION needed.
# DRIVE_DEFAULT_FOLDER_ID=your-folder-id

# Optional: per-jurisdiction Drive folders (only if you need different folders per country)
# DRIVE_FOLDER_IDS_BY_JURISDICTION={"LU":"...","NO":"...",...}

# Google OAuth2 — enables file uploads in sync-integrations (service accounts cannot upload files)
# Run: npm run drive-get-oauth-token  to get your refresh token (one-time setup)
# Create OAuth 2.0 Client ID (Desktop app) at https://console.cloud.google.com/apis/credentials
# GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token

# Resend (optional — for email notifications from the AI Agent chat)
# Sign up at https://resend.com and create an API key
# RESEND_API_KEY=re_your-api-key
# RESEND_FROM_EMAIL=Hopae Compliance <compliance@yourdomain.com>
